@model MVCProje.Models.Entity.Products
@{
    ViewBag.Title = "AddProduct";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<form class="form-group" method="post">
    <div>
        <label>Ürün Adı</label>
        <input type="text" class="form-control" name="ProductName" />
    </div>
    <div style="margin-top:15px">
        <label>Kategori Seçiniz</label>
        @Html.DropDownListFor(x=>x.Categories.CategoryId,(List<SelectListItem>)ViewBag.categories, new {@class="form-control" })
    </div>
    <div style="margin-top:15px">
        <label>Fiyat</label>
        <input type="text" class="form-control" name="ProductPrice" />
    </div>
    <div style="margin-top:15px">
        <label>Stok</label>
        <input type="text" class="form-control" name="ProductStock" />
    </div>
    <div style="margin-top:15px">
        <label>Açıklama</label>
        <textarea class="form-control" name="ProductDescription" rows="5"></textarea>
    </div>
    <div style="margin-top:15px">
        <button class="btn btn-info">Ürün Ekle</button>
    </div>
</form>
