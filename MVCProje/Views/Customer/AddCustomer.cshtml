@model MVCProje.Models.Entity.Customers
@{
    ViewBag.Title = "AddCustomer";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<form class="form-group" method="post">
    <div>
        <label>Müşteri Adı</label>
        @Html.TextBoxFor(c=>c.CustomerName,new {@class="form-control" })
        @Html.ValidationMessageFor(c=>c.CustomerName,"",new {@style="color:red"})
        @*<input type="text" class="form-control" name="CustomerName" />*@
    </div>
    <div style="margin-top:15px">
        <label>Müşteri Soyadı</label>
        <input type="text" class="form-control" name="CustomerSurname" />
    </div>
    <div style="margin-top:15px">
        <label>E-Mail</label>
        <input type="email" class="form-control" name="CustomerEmail" />
    </div>
    <div style="margin-top:15px">
        <label>İlçe</label>
        <input type="text" class="form-control" name="CustomerDistrict" />
    </div>
    <div style="margin-top:15px">
        <label>Şehir</label>
        <input type="text" class="form-control" name="CustomerCity" />
    </div>
    <div style="margin-top:15px">
        <label>Ülke</label>
        <input type="text" class="form-control" name="CustomerCountry" />
    </div>
    <div style="margin-top:15px">
        <label>Cinsiyet</label>
        <input type="text" class="form-control" name="CustomerGender" />
    </div>
    <div style="margin-top:15px">
        <label>Bakiye</label>
        <input type="number" class="form-control" name="CustomerBalance" />
    </div>
    <div style="margin-top:15px">
        <button class="btn btn-info" id="btnAddCustomer">Müşteri Ekle</button>
    </div>
    <script>
        $('#btnAddCustomer').click(function () {
            alert('Müşteri Ekleme İşlemi Yapıldı...')
        })
    </script>
</form>

